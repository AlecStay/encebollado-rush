; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Jocay Rush"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

HighScoreManager="*res://scripts/high_score_manager.gd"
GameState="*res://scripts/game_state.gd"
SettingsManager="*res://scripts/settings_manager.gd"
DebugCommands="*res://scripts/debug_commands.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[gui]

theme/custom_font="res://grapesoda_2/GrapeSoda.ttf"

[editor_plugins]

enabled=PackedStringArray("res://addons/funplay_mcp/plugin.cfg")

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters=0
